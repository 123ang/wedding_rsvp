# MySQL (create database `wedding_rsvp` and import schema/data before starting)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=wedding_rsvp

# Security
JWT_SECRET=replace-with-at-least-32-random-characters
ADMIN_JWT_EXPIRES_IN=12h
GUEST_JWT_EXPIRES_IN=30d
CORS_ORIGINS=https://your-wedding-domain.example
TRUST_PROXY_HEADERS=false
MAX_VIDEO_UPLOAD_MB=100
PRIVATE_VIDEO_DIR=/var/lib/wedding-rsvp/private/videos

# Must match nginx (sites-available jsang-psong-wedding.com → localhost:3002)
PORT=3002
NODE_ENV=production
