# Dependencies
node_modules/
package-lock.json
api/.venv/
yarn.lock

# Production build
dist/
build/
# Don't ignore website/public/ – favicon, photos, music must be in repo for deploy

# Environment variables
.env
.env.local
.env.production

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*

